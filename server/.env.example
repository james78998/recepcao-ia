# ============================================================
# Recepção IA — Backend — Exemplo de Variáveis de Ambiente
# Copie para .env e preencha com os valores reais.
# NUNCA commite o .env real.
# ============================================================

# Ambiente de execução
NODE_ENV=development

# Porta do servidor
PORT=3000

# URL pública base do backend
API_BASE_URL=http://localhost:3000

# Origens permitidas para CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# Banco de dados (Prisma — Fase 1)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/recepcao_ia?schema=public

# Autenticação JWT (Fase 1)
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-e-aleatorio
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# WhatsApp Business Cloud API (Fase 2)
# WHATSAPP_TOKEN: System User Token permanente — usado para envio (Fase futura)
WHATSAPP_TOKEN=seu-system-user-token
# WHATSAPP_PHONE_NUMBER_ID: referência de dev; em produção o roteamento usa Tenant.whatsappPhoneNumberId
WHATSAPP_PHONE_NUMBER_ID=seu-phone-number-id
# WHATSAPP_VERIFY_TOKEN: token que você define no painel da Meta ao registrar o webhook
WHATSAPP_VERIFY_TOKEN=defina-um-token-secreto-qualquer
# WHATSAPP_APP_SECRET: App Secret do Meta App — valida a assinatura HMAC-SHA256 do webhook
WHATSAPP_APP_SECRET=seu-app-secret-do-meta
