# ============================================================
# Recepção IA — Backend — Exemplo de Variáveis de Ambiente
# Copie para .env e preencha com os valores reais.
# NUNCA commite o .env real.
# ============================================================

# Ambiente de execução
NODE_ENV=development

# Porta do servidor
PORT=3000

# URL pública base do backend
API_BASE_URL=http://localhost:3000

# Origens permitidas para CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# Banco de dados (Prisma — Fase 1)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/recepcao_ia?schema=public

# Autenticação JWT (Fase 1)
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-e-aleatorio
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Autenticação do Super Admin (plataforma) — realm separado do Tenant, NUNCA reutilizar JWT_SECRET aqui
ADMIN_JWT_SECRET=troque-por-um-segredo-forte-e-diferente-do-jwt-secret
ADMIN_JWT_EXPIRES_IN=2h

# Criptografia de segredos por tenant (Fase 6 — Configuração do Tenant)
# TENANT_SECRETS_ENCRYPTION_KEY: chave AES-256 de 32 bytes em base64 — usada para
# criptografar chave OpenAI, token WhatsApp e credenciais de integrações por tenant.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TENANT_SECRETS_ENCRYPTION_KEY=troque-por-uma-chave-de-32-bytes-em-base64

# WhatsApp Business Cloud API (Fase 2)
# WHATSAPP_TOKEN: System User Token permanente — usado para envio
WHATSAPP_TOKEN=seu-system-user-token
# WHATSAPP_PHONE_NUMBER_ID: referência de dev; em produção o roteamento usa Tenant.whatsappPhoneNumberId
WHATSAPP_PHONE_NUMBER_ID=seu-phone-number-id
# WHATSAPP_VERIFY_TOKEN: token que você define no painel da Meta ao registrar o webhook
WHATSAPP_VERIFY_TOKEN=defina-um-token-secreto-qualquer
# WHATSAPP_APP_SECRET: App Secret do Meta App — valida a assinatura HMAC-SHA256 do webhook
WHATSAPP_APP_SECRET=seu-app-secret-do-meta
# WHATSAPP_DRY_RUN: se true, não chama a Meta API — simula envio com wamid fictício (útil em dev/teste)
WHATSAPP_DRY_RUN=false

# OpenAI (Fase 3)
# OPENAI_API_KEY: chave secreta da API — NUNCA expor no frontend
OPENAI_API_KEY=sk-proj-sua-chave-aqui
# OPENAI_MODEL: modelo a usar (gpt-4o-mini é o mais barato; padrão se omitido)
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS: limite de tokens na resposta gerada (padrão: 300)
OPENAI_MAX_TOKENS=300
# OPENAI_HISTORY_LIMIT: número de mensagens anteriores enviadas como contexto (padrão: 10)
OPENAI_HISTORY_LIMIT=10
# OPENAI_DRY_RUN: se true, não chama a API real — salva resposta simulada (útil em dev/teste)
OPENAI_DRY_RUN=false















