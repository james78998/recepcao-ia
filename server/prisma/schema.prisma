generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  RECEPTIONIST
}

enum AdminRole {
  SUPER_ADMIN
}

enum LeadStatus {
  NOVO
  DEMONSTRACAO
  PROPOSTA
  CLIENTE_ATIVO
  PERDIDO
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
}

enum MessageStatus {
  DRAFT    // sugestão da IA — salva, mas não enviada
  PENDING  // aprovada para envio — fila (Fase futura)
  SENT     // confirmada enviada ou recebida com sucesso
  FAILED   // falha no envio (Fase futura)
}

enum ConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
  EXPIRED
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  DENTAL_OFFICE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELED
  COMPLETED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

// Eventos de domínio que o Motor de Automações pode disparar para webhooks
// externos (n8n, Zapier, Make, Power Automate, Google Apps Script, ERPs,
// Dental Office ou qualquer outro consumidor HTTP). APPOINTMENT_CREATED e
// PAYMENT_PAID ainda não têm emissor no código (reservados para as Fases 3/4
// do roadmap), mas já existem aqui para o tenant poder configurar o webhook
// com antecedência.
enum AutomationEvent {
  LEAD_CREATED
  LEAD_UPDATED
  CONVERSATION_CREATED
  MESSAGE_RECEIVED
  MESSAGE_SENT
  APPOINTMENT_CREATED
  PAYMENT_PAID
  USER_PASSWORD_RESET_REQUESTED
  USER_PASSWORD_RESET_COMPLETED
  AUTOMATION_TEST // reservado ao endpoint de teste manual — nunca oferecido para assinatura pelo tenant
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model Tenant {
  id                    String  @id @default(uuid())
  name                  String
  email                 String  @unique
  phone                 String? // telefone de contato da clínica, exibido em Configurações
  address               String? // endereço da clínica, exibido em Configurações
  logoPath              String? // caminho/chave do logo (preparado para upload futuro em S3/R2/MinIO/local)
  whatsappPhoneNumberId String? // phone_number_id da Meta — identifica o tenant no webhook
  aiEnabled             Boolean @default(true) // controla geração de rascunhos pela IA por tenant

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  leads             Lead[]
  conversations     Conversation[]
  messages          Message[]
  aiConfig          TenantAiConfig?
  whatsappConfig    TenantWhatsappConfig?
  scheduleConfig    TenantScheduleConfig?
  businessHours     TenantBusinessHour[]
  integrations      TenantIntegration[]
  auditLogs         AuditLog[]
  automationWebhooks AutomationWebhook[]
  automationDispatchLogs AutomationDispatchLog[]
  tenantModules     TenantModule[]
  appointments      Appointment[]

  @@map("tenants")
}

// Catálogo de módulos comerciais da plataforma (CRM, WhatsApp, IA, Agenda,
// Motor de Automações etc.). Fonte da verdade em código: server/src/constants/modules.js
// (seed/backfill via server/scripts/backfillModules.js). Dashboard, Configurações e
// Perfil não são módulos — ficam sempre disponíveis, fora deste catálogo.
model Module {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantModules TenantModule[]

  @@map("modules")
}

// Habilitação de um módulo para um tenant específico. Uma linha por par
// (tenant, módulo); tenants novos recebem todas as linhas do catálogo já
// habilitadas no onboarding (ver tenantOnboardingService), e tenants
// existentes são cobertos pelo backfill (ver backfillModules.js).
model TenantModule {
  id       String  @id @default(uuid())
  tenantId String
  moduleId String
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@map("tenant_modules")
}

// Parâmetros de geração de IA por tenant. basePrompt (regras fixas do produto,
// não editáveis pelo cliente) vive em código (aiService) — aqui só o que é
// configurável: chave, modelo, prompt customizado e limites de geração.
model TenantAiConfig {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  openAiApiKeyEncrypted  String? // nunca em texto puro — ver utils/encryption.js
  openAiModel            String? // null = usa OPENAI_MODEL do env
  customPrompt           String? // instruções adicionais da clínica, somadas ao basePrompt fixo
  temperature            Float?  // 0–2; null = usa padrão do env/código
  maxTokens              Int?    // null = usa OPENAI_MAX_TOKENS do env

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_ai_configs")
}

model TenantWhatsappConfig {
  id                    String            @id @default(uuid())
  tenantId              String            @unique
  accessTokenEncrypted  String? // nunca em texto puro — ver utils/encryption.js
  businessAccountId     String?
  displayName           String? // nome da conta/número exibido na tela
  connectionStatus      ConnectionStatus  @default(NOT_CONNECTED)
  webhookVerified       Boolean           @default(false)
  connectedAt           DateTime?
  lastSync              DateTime?
  lastError             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_whatsapp_configs")
}

// Fuso horário e parâmetros de agenda. Horário de atendimento por dia
// vive em TenantBusinessHour (tabela própria, não JSON) — ver abaixo.
model TenantScheduleConfig {
  id                            String   @id @default(uuid())
  tenantId                      String   @unique
  timezone                      String   @default("America/Sao_Paulo")
  defaultAppointmentDurationMin Int      @default(30)
  bufferBetweenAppointmentsMin  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_schedule_configs")
}

// Uma linha por dia da semana — permite validação, consultas SQL diretas
// (ex.: "tenants abertos aos sábados") e integração futura com Google
// Calendar/Dental Office sem parsing de JSON.
model TenantBusinessHour {
  id         String    @id @default(uuid())
  tenantId   String
  dayOfWeek  DayOfWeek
  enabled    Boolean   @default(true)
  startTime  String? // "HH:MM"
  endTime    String? // "HH:MM"
  lunchStart String? // "HH:MM", opcional
  lunchEnd   String? // "HH:MM", opcional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
  @@map("tenant_business_hours")
}

// Uma linha por provedor conectado — mesmo formato serve Google Calendar,
// Dental Office e futuros provedores (Mercado Pago, Stripe etc.), sem
// migration nova a cada integração.
model TenantIntegration {
  id                    String              @id @default(uuid())
  tenantId              String
  provider              IntegrationProvider
  providerVersion       String? // versão da API do provedor, facilita futuras migrações
  status                ConnectionStatus    @default(NOT_CONNECTED)
  credentialsEncrypted  Json? // blob criptografado — nunca texto puro
  metadata              Json? // dados não sensíveis (ex.: calendarId, clinicId, lastSyncAt)
  connectedAt           DateTime?
  lastError             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("tenant_integrations")
}

// Motor de Automações — um webhook de saída por linha. Cada tenant pode
// cadastrar N webhooks, cada um escutando um subconjunto de AutomationEvent.
// O consumidor do webhook é agnóstico (n8n, Zapier, Make, Power Automate,
// Google Apps Script, ERP próprio, Dental Office etc.) — a plataforma só
// conhece a URL e assina o payload em HMAC com o secret gerado aqui.
// Exclusão é sempre soft delete (deletedAt) para preservar histórico de
// auditoria e permitir recuperação; nunca DELETE físico.
model AutomationWebhook {
  id                String            @id @default(uuid())
  tenantId          String
  name              String // rótulo livre definido pelo tenant (ex.: "n8n — Qualificação")
  url               String
  signingSecretEnc  String // HMAC secret gerado pelo sistema — nunca texto puro, ver utils/encryption.js
  enabled           Boolean           @default(true)
  events            AutomationEvent[] @default([])
  lastError         String?
  lastSuccessAt     DateTime?
  deletedAt         DateTime? // soft delete — nunca excluído fisicamente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs   AutomationDispatchLog[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("automation_webhooks")
}

// Uma linha por tentativa de entrega — o histórico completo de retries fica
// visível (não sobrescreve). deliveryId identifica uma entrega a UM webhook
// específico (compartilhado pelas até 3 tentativas dessa entrega); eventId
// identifica o evento de domínio de origem (compartilhado entre todos os
// webhooks que o receberam no mesmo fan-out). errorType classifica a falha
// para permitir agregações de métricas/dashboards sem parsear errorMessage.
model AutomationDispatchLog {
  id           String           @id @default(uuid())
  tenantId     String
  webhookId    String
  event        AutomationEvent
  eventId      String
  deliveryId   String
  urlSnapshot  String
  payload      Json
  httpStatus   Int?
  success      Boolean          @default(false)
  errorType    String? // TIMEOUT | NETWORK_ERROR | HTTP_ERROR | PAYLOAD_TOO_LARGE | BLOCKED_URL
  errorMessage String?
  attempt      Int              @default(1)
  durationMs   Int?
  createdAt    DateTime         @default(now())

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webhook AutomationWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([webhookId, createdAt])
  @@index([deliveryId])
  @@map("automation_dispatch_logs")
}

// Trilha de auditoria de alterações em configurações do tenant.
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String // ex.: "UPDATE_AI_CONFIG"
  resource  String // ex.: "TenantAiConfig"
  oldValue  Json? // nunca contém segredo em texto puro — ver auditLogService
  newValue  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, resource])
  @@map("audit_logs")
}

// Conta da equipe da plataforma (Recepção IA), fora do escopo de qualquer Tenant.
// Não possui tenantId por definição — gerenciamento de tenants é feito de fora do multi-tenant.
model AdminUser {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(SUPER_ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AdminAuditLog[]

  @@map("admin_users")
}

// Trilha de auditoria das ações do Super Admin (realm de AdminUser) — separada
// de AuditLog, que audita ações de User dentro de um tenant. tenantId é
// opcional porque nem toda ação administrativa é sobre um tenant específico
// (reservado para futuras ações globais da plataforma).
model AdminAuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  tenantId    String?
  action      String // ex.: "MODULE_ENABLED", "MODULE_DISABLED", "MODULES_BULK_UPDATED"
  resource    String // ex.: "TenantModule"
  resourceId  String? // ex.: moduleKey ou TenantModule.id afetado
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([tenantId])
  @@map("admin_audit_logs")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(RECEPTIONIST)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]

  @@index([tenantId])
  @@map("users")
}

// Token de recuperação de senha — uma linha por pedido. tokenHash é SHA-256
// do token enviado por e-mail (nunca o valor em texto puro, mesmo espírito de
// AutomationWebhook.signingSecretEnc). Uso único: usedAt marcado no reset;
// pedidos antigos são invalidados a cada novo pedido e após reset bem-sucedido.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Lead {
  id              String     @id @default(uuid())
  tenantId        String
  name            String
  phone           String
  phoneNormalized String?    // apenas dígitos (E.164 sem +), para busca via WhatsApp
  email           String?
  company         String?
  segment         String?
  status          LeadStatus @default(NOVO)
  source          String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]
  appointments  Appointment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, phoneNormalized])
  @@map("leads")
}

// Compromisso da Agenda (Fase 3 do roadmap). leadId é opcional — nem todo
// evento tem um Lead já cadastrado no CRM (ex.: demonstração com prospect
// novo); clientName cobre esse caso, e é preenchido a partir do Lead quando
// leadId é informado. Preparado para sincronização futura com Google Calendar
// (ver TenantIntegration/TenantScheduleConfig), sem acoplamento a ela ainda.
model Appointment {
  id          String            @id @default(uuid())
  tenantId    String
  leadId      String?
  title       String
  clientName  String?
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(SCHEDULED)
  googleEventId String? // id do evento espelhado no Google Calendar (ver googleCalendarSyncService), null se não sincronizado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@map("appointments")
}

model Conversation {
  id        String             @id @default(uuid())
  tenantId  String
  leadId    String
  channel   MessageChannel     @default(WHATSAPP)
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([tenantId])
  @@index([leadId])
  @@index([tenantId, status])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  tenantId       String
  conversationId String
  leadId         String
  direction      MessageDirection
  content        String
  status         MessageStatus    @default(SENT) // INBOUND=SENT; OUTBOUND IA=DRAFT
  aiGenerated    Boolean          @default(false)
  metadata       Json?            // dados do modelo IA (model, generatedAt, etc.)
  wamid          String?          @unique // ID único da mensagem no WhatsApp (idempotência)
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@index([tenantId, status])
  @@map("messages")
}
