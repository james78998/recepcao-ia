# ============================================================================
# Recepção IA — Exemplo de Variáveis de Ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha com os valores reais do ambiente.
# NUNCA commite o arquivo `.env` — apenas este `.env.example`.
#
# ATENÇÃO: tudo com prefixo VITE_ é EXPOSTO no navegador (público).
# Jamais coloque segredos (API keys, tokens) em variáveis VITE_.
# Segredos vivem APENAS no backend.
# ============================================================================


# ============================================================================
# FRONTEND (Vite)
# Apenas variáveis com prefixo VITE_ são expostas ao bundle do navegador.
# ============================================================================

# URL base da API do backend consumida pelo frontend (camada services/).
VITE_API_BASE_URL=http://localhost:3000/api

# Ambiente da aplicação frontend: development | staging | production
VITE_APP_ENV=development

# Nome público da aplicação (exibido na UI).
VITE_APP_NAME=Recepção IA

# (Opcional) Chave pública de analytics/monitoramento de frontend.
VITE_ANALYTICS_KEY=


# ============================================================================
# BACKEND (servidor — futuro)
# ============================================================================

# Ambiente de execução do servidor: development | staging | production
NODE_ENV=development

# Porta em que o servidor backend irá escutar.
PORT=3000

# URL pública base do backend (usada em webhooks e callbacks).
API_BASE_URL=http://localhost:3000

# Origens permitidas para CORS (separadas por vírgula).
CORS_ORIGIN=http://localhost:5173


# ============================================================================
# BANCO DE DADOS (PostgreSQL + Prisma)
# ============================================================================

# String de conexão completa usada pelo Prisma.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL=postgresql://usuario:senha@localhost:5432/recepcao_ia?schema=public

# (Opcional) URL de conexão direta sem pool, usada por migrations.
DIRECT_URL=postgresql://usuario:senha@localhost:5432/recepcao_ia?schema=public


# ============================================================================
# AUTENTICAÇÃO (JWT)
# ============================================================================

# Segredo para assinar os access tokens. Use um valor longo e aleatório.
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio

# Tempo de expiração do access token (ex.: 15m, 1h).
JWT_EXPIRES_IN=15m

# Segredo para assinar os refresh tokens (diferente do JWT_SECRET).
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-e-aleatorio

# Tempo de expiração do refresh token (ex.: 7d, 30d).
JWT_REFRESH_EXPIRES_IN=7d

# Número de rounds do bcrypt para hash de senhas.
BCRYPT_SALT_ROUNDS=12

# Segredo para assinar os tokens do Super Admin (painel da plataforma).
# Realm de autenticação separado do Tenant — NUNCA reutilizar o mesmo valor de JWT_SECRET.
ADMIN_JWT_SECRET=troque-por-um-segredo-forte-e-diferente-do-jwt-secret

# Tempo de expiração do token do Super Admin (ex.: 2h). Sem refresh token nesta etapa.
ADMIN_JWT_EXPIRES_IN=2h

# Chave AES-256 (32 bytes, base64) usada para criptografar segredos por tenant
# (chave OpenAI, token WhatsApp, credenciais de integrações). NUNCA expor no frontend.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TENANT_SECRETS_ENCRYPTION_KEY=troque-por-uma-chave-de-32-bytes-em-base64


# ============================================================================
# OPENAI (motor de IA da recepção virtual)
# ============================================================================

# Chave secreta da API da OpenAI. NUNCA expor no frontend.
OPENAI_API_KEY=sk-coloque-sua-chave-aqui

# Modelo padrão utilizado nas respostas da IA.
OPENAI_MODEL=gpt-4o-mini

# (Opcional) ID da organização na OpenAI.
OPENAI_ORG_ID=

# Limite máximo de tokens por resposta.
OPENAI_MAX_TOKENS=1024


# ============================================================================
# WHATSAPP BUSINESS CLOUD API
# ============================================================================

# Token de acesso permanente da Cloud API. NUNCA expor no frontend.
WHATSAPP_TOKEN=coloque-seu-token-aqui

# ID do número de telefone do WhatsApp Business (phone_number_id).
WHATSAPP_PHONE_NUMBER_ID=000000000000000

# ID da conta WhatsApp Business (WABA ID).
WHATSAPP_BUSINESS_ACCOUNT_ID=000000000000000

# Token de verificação usado na validação do webhook (GET hub.challenge).
WHATSAPP_VERIFY_TOKEN=defina-um-token-de-verificacao

# Versão da Graph API utilizada nas chamadas.
WHATSAPP_API_VERSION=v20.0


# ============================================================================
# META (plataforma de apps — credenciais base usadas por WhatsApp/Meta)
# ============================================================================

# ID do app criado no Meta for Developers.
META_APP_ID=coloque-o-app-id

# Segredo do app Meta. Usado para validar assinatura dos webhooks. NUNCA expor.
META_APP_SECRET=coloque-o-app-secret

# Token de verificação genérico para webhooks da Meta.
META_WEBHOOK_VERIFY_TOKEN=defina-um-token-de-verificacao


# ============================================================================
# GOOGLE CALENDAR (agendamento de consultas)
# ============================================================================

# Client ID da credencial OAuth 2.0 do Google Cloud.
GOOGLE_CLIENT_ID=coloque-o-client-id.apps.googleusercontent.com

# Client Secret da credencial OAuth 2.0. NUNCA expor no frontend.
GOOGLE_CLIENT_SECRET=coloque-o-client-secret

# URL de callback do fluxo OAuth do Google.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Escopos solicitados ao Google (separados por espaço).
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar


# ============================================================================
# DENTAL OFFICE API (integração odontológica)
# ============================================================================

# URL base da API do Dental Office.
DENTAL_OFFICE_API_URL=https://api.dentaloffice.example.com

# Chave de API do Dental Office. NUNCA expor no frontend.
DENTAL_OFFICE_API_KEY=coloque-sua-chave-aqui

# (Opcional) Segredo usado para validar webhooks do Dental Office.
DENTAL_OFFICE_WEBHOOK_SECRET=


# ============================================================================
# MERCADO PAGO (pagamentos — Brasil)
# ============================================================================

# Access token da conta Mercado Pago. NUNCA expor no frontend.
MERCADOPAGO_ACCESS_TOKEN=coloque-seu-access-token

# Chave pública do Mercado Pago (usada no checkout do lado do cliente).
MERCADOPAGO_PUBLIC_KEY=coloque-sua-public-key

# Segredo para validar a assinatura dos webhooks do Mercado Pago.
MERCADOPAGO_WEBHOOK_SECRET=coloque-o-webhook-secret


# ============================================================================
# STRIPE (pagamentos — internacional)
# ============================================================================

# Chave secreta da API Stripe. NUNCA expor no frontend.
STRIPE_SECRET_KEY=sk_test_coloque-sua-chave

# Chave publicável da Stripe (pode ser usada no frontend, é pública).
STRIPE_PUBLISHABLE_KEY=pk_test_coloque-sua-chave

# Segredo de assinatura dos webhooks da Stripe.
STRIPE_WEBHOOK_SECRET=whsec_coloque-o-segredo


# ============================================================================
# MOTOR DE AUTOMAÇÕES (webhooks de saída por tenant)
# ============================================================================
# Não há variável de ambiente própria: cada tenant cadastra seus próprios
# webhooks (URL, eventos, secret de assinatura) pelo painel, armazenados em
# AutomationWebhook e criptografados com TENANT_SECRETS_ENCRYPTION_KEY (acima).
# O consumidor é agnóstico — n8n, Zapier, Make, Power Automate, Google Apps
# Script, ERP próprio, Dental Office etc. são exemplos, não uma integração fixa.


# ============================================================================
# EMAIL (SMTP — notificações transacionais)
# ============================================================================

# Host do servidor SMTP.
SMTP_HOST=smtp.example.com

# Porta do servidor SMTP (ex.: 587 para TLS, 465 para SSL).
SMTP_PORT=587

# Usar conexão segura (SSL/TLS): true | false
SMTP_SECURE=false

# Usuário de autenticação SMTP.
SMTP_USER=coloque-o-usuario

# Senha de autenticação SMTP. NUNCA expor no frontend.
SMTP_PASSWORD=coloque-a-senha

# Remetente padrão dos emails enviados.
SMTP_FROM_EMAIL=nao-responda@recepcao-ia.example.com

# Nome de exibição do remetente.
SMTP_FROM_NAME=Recepção IA


# ============================================================================
# UPLOADS (armazenamento de arquivos)
# ============================================================================

# Driver de armazenamento: local | s3
STORAGE_DRIVER=local

# Diretório local para uploads (quando STORAGE_DRIVER=local).
UPLOAD_DIR=./uploads

# Tamanho máximo de upload em bytes (ex.: 5242880 = 5 MB).
MAX_UPLOAD_SIZE=5242880

# (Quando STORAGE_DRIVER=s3) Nome do bucket.
S3_BUCKET=

# (Quando STORAGE_DRIVER=s3) Região do bucket.
S3_REGION=

# (Quando STORAGE_DRIVER=s3) Access key. NUNCA expor no frontend.
S3_ACCESS_KEY_ID=

# (Quando STORAGE_DRIVER=s3) Secret key. NUNCA expor no frontend.
S3_SECRET_ACCESS_KEY=

# (Quando STORAGE_DRIVER=s3) Endpoint customizado (S3-compatível, opcional).
S3_ENDPOINT=


# ============================================================================
# LOGS (observabilidade)
# ============================================================================

# Nível de log: error | warn | info | http | debug
LOG_LEVEL=info

# Formato de log: json | pretty
LOG_FORMAT=pretty

# (Opcional) DSN do Sentry para captura de erros. NUNCA expor segredo no front.
SENTRY_DSN=
